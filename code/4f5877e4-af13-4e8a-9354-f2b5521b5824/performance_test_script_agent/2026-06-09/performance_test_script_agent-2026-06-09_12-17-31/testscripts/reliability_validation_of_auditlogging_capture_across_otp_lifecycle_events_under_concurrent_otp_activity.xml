        <stringProp name="variableNames">user_id,username,msisdn,email</stringProp>
        <boolProp name="ignoreFirstLine">true</boolProp>
        <stringProp name="delimiter">,</stringProp>
        <boolProp name="quotedData">false</boolProp>
        <boolProp name="recycle">true</boolProp>
        <boolProp name="stopThread">false</boolProp>
        <stringProp name="shareMode">shareMode.all</stringProp>
      </CSVDataSet>
      <hashTree />

      <CSVDataSet guiclass="TestBeanGUI" testclass="CSVDataSet" testname="CSV - OTP/Validation Inputs" enabled="true">
        <stringProp name="filename">data/otp_inputs.csv</stringProp>
