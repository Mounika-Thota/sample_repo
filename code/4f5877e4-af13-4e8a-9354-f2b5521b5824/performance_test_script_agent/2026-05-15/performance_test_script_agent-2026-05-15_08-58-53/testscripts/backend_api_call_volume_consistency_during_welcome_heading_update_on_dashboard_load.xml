<?xml version="1.0" encoding="UTF-8"?>
<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.6.3">
  <hashTree>
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="Dashboard Welcome Heading Update Backend API Call Volume Performance Test" enabled="true">
      <stringProp name="TestPlan.comments">Performance test for backend API call volume consistency during dashboard welcome heading update. Baseline and post-change measurements under controlled load.</stringProp>
      <boolProp name="TestPlan.functional_mode">false</boolProp>
      <boolProp name="TestPlan.serialize_threadgroups">false</boolProp>
    </TestPlan>
    <hashTree>
      <!-- Baseline Measurement Thread Group (Pre-change) -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="BaselineDashboardLoadPreChange" enabled="true">
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel">
          <boolProp name="LoopController.continue_forever">false</boolProp>
          <stringProp name="LoopController.loops">1</stringProp>
        </elementProp>
        <stringProp name="ThreadGroup.num_threads">100</stringProp>
        <stringProp name="ThreadGroup.ramp_time">10</stringProp>
        <longProp name="ThreadGroup.start_time">0</longProp>
        <longProp name="ThreadGroup.end_time">0</longProp>
        <boolProp name="ThreadGroup.scheduler">false</boolProp>
      </ThreadGroup>
      <hashTree>
        <!-- HTTP Request: Dashboard Load (Pre-change) -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="DashboardLoad_PreChange" enabled="true">
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments"/>
          </elementProp>
          <stringProp name="HTTPSampler.domain">${DASHBOARD_API_DOMAIN}</stringProp>
          <stringProp name="HTTPSampler.port">${DASHBOARD_API_PORT}</stringProp>
          <stringProp name="HTTPSampler.protocol">${DASHBOARD_API_PROTOCOL}</stringProp>
          <stringProp name="HTTPSampler.path">/api/dashboard/load</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <boolProp name="HTTPSampler.postBodyRaw">false</boolProp>
        </HTTPSamplerProxy>
        <hashTree>
          <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="HTTP Header Manager" enabled="true">
            <collectionProp name="HeaderManager.headers">
              <elementProp name="" elementType="Header">
                <stringProp name="Header.name">Authorization</stringProp>
                <stringProp name="Header.value">${AUTH_TOKEN}</stringProp>
              </elementProp>
              <elementProp name="" elementType="Header">
                <stringProp name="Header.name">Content-Type</stringProp>
                <stringProp name="Header.value">application/json</stringProp>
              </elementProp>
            </collectionProp>
          </HeaderManager>
          <hashTree/>

          <!-- Response Time Assertion -->
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Pre-Change Response Time SLA" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp>2</stringProp>
            </collectionProp>
            <stringProp name="Assertion.test_field">Assertion.response_time</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">2</intProp> <!-- 2=Less Than -->
          </ResponseAssertion>
          <hashTree/>

          <!-- Error Rate Assertion (Status Code 2xx) -->
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Pre-Change Error Rate Assertion" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp>200</stringProp>
              <stringProp>201</stringProp>
            </collectionProp>
            <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">2</intProp> <!-- 2=Equals -->
          </ResponseAssertion>
          <hashTree/>
        </hashTree>
      </hashTree>

      <!-- Post-Change Measurement Thread Group -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="PostChangeDashboardLoad" enabled="true">
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel">
          <boolProp name="LoopController.continue_forever">false</boolProp>
          <stringProp name="LoopController.loops">1</stringProp>
        </elementProp>
        <stringProp name="ThreadGroup.num_threads">100</stringProp>
        <stringProp name="ThreadGroup.ramp_time">10</stringProp>
        <longProp name="ThreadGroup.start_time">0</longProp>
        <longProp name="ThreadGroup.end_time">0</longProp>
        <boolProp name="ThreadGroup.scheduler">false</boolProp>
      </ThreadGroup>
      <hashTree>
        <!-- HTTP Request: Dashboard Load (Post-change) -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="DashboardLoad_PostChange" enabled="true">
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments"/>
          </elementProp>
          <stringProp name="HTTPSampler.domain">${DASHBOARD_API_DOMAIN}</stringProp>
          <stringProp name="HTTPSampler.port">${DASHBOARD_API_PORT}</stringProp>
          <stringProp name="HTTPSampler.protocol">${DASHBOARD_API_PROTOCOL}</stringProp>
          <stringProp name="HTTPSampler.path">/api/dashboard/load</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <boolProp name="HTTPSampler.postBodyRaw">false</boolProp>
        </HTTPSamplerProxy>
        <hashTree>
          <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="HTTP Header Manager" enabled="true">
            <collectionProp name="HeaderManager.headers">
              <elementProp name="" elementType="Header">
                <stringProp name="Header.name">Authorization</stringProp>
                <stringProp name="Header.value">${AUTH_TOKEN}</stringProp>
              </elementProp>
              <elementProp name="" elementType="Header">
                <stringProp name="Header.name">Content-Type</stringProp>
                <stringProp name="Header.value">application/json</stringProp>
              </elementProp>
            </collectionProp>
          </HeaderManager>
          <hashTree/>

          <!-- Response Time Assertion -->
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Post-Change Response Time SLA" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp>2</stringProp>
            </collectionProp>
            <stringProp name="Assertion.test_field">Assertion.response_time</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">2</intProp>
          </ResponseAssertion>
          <hashTree/>

          <!-- Error Rate Assertion (Status Code 2xx) -->
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Post-Change Error Rate Assertion" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp>200</stringProp>
              <stringProp>201</stringProp>
            </collectionProp>
            <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">2</intProp>
          </ResponseAssertion>
          <hashTree/>
        </hashTree>
      </hashTree>

      <!-- Listener: Backend API Call Metrics & Performance Results -->
      <ResultCollector guiclass="SummaryReport" testclass="ResultCollector" testname="API Call Summary Report" enabled="true">
        <boolProp name="ResultCollector.error_logging">true</boolProp>
        <objProp>
          <name>saveConfig</name>
          <value class="SampleSaveConfiguration">
            <boolProp name="time">true</boolProp>
            <boolProp name="latency">true</boolProp>
            <boolProp name="success">true</boolProp>
            <boolProp name="label">true</boolProp>
            <boolProp name="responseCode">true</boolProp>
            <boolProp name="responseMessage">true</boolProp>
            <boolProp name="threadName">true</boolProp>
            <boolProp name="dataType">true</boolProp>
            <boolProp name="assertions">true</boolProp>
            <boolProp name="sampleCount">true</boolProp>
            <boolProp name="errorCount">true</boolProp>
            <boolProp name="hostname">true</boolProp>
          </value>
        </objProp>
        <stringProp name="filename">${RESULTS_FILE}</stringProp>
      </ResultCollector>
      <hashTree/>
      <!-- Add additional ResultCollector elements for JTL and APM tool integrations as needed -->
    </hashTree>
  </hashTree>
</jmeterTestPlan>