            <stringProp name="HTTPSampler.embedded_url_re"></stringProp>
          </HTTPSamplerProxy>
          <hashTree>
            <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Assert HTTP 2xx/3xx" enabled="true">
              <collectionProp name="Asserion.test_strings">
                <stringProp name="200">200</stringProp>
                <stringProp name="201">201</stringProp>
                <stringProp name="202">202</stringProp>
                <stringProp name="204">204</stringProp>
                <stringProp name="301">301</stringProp>
                <stringProp name="302">302</stringProp>
                <stringProp name="304">304</stringProp>
              </collectionProp>
              <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
              <boolProp name="Assertion.assume_success">false</boolProp>
              <intProp name="Assertion.test_type">2</intProp>
            </ResponseAssertion>
            <hashTree/>
          </hashTree>

          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Log: Disruption marker (manual)" enabled="false">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">// Enable and duplicate this sampler to mark disruption windows in jmeter.log
// Example: set testname to 'Log: DISRUPTION_START - restart service X'
// and later 'Log: DISRUPTION_END - restart service X'
log.info(vars.get('TIMELINE_LOG_PREFIX') + ' ' + ctx.getCurrentSampler().getName() + ' epoch_ms=' + System.currentTimeMillis());</stringProp>
          </JSR223Sampler>
          <hashTree/>

          <ConstantTimer guiclass="ConstantTimerGui" testclass="ConstantTimer" testname="Pacing" enabled="true">
            <stringProp name="ConstantTimer.delay">${PACING_MS}</stringProp>
          </ConstantTimer>
          <hashTree/>
        </hashTree>

        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Log: Test end marker (best-effort)" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">// This will only execute when the test is stopped gracefully.
log.info(vars.get('TIMELINE_LOG_PREFIX') + ' TEST_STOP epoch_ms=' + System.currentTimeMillis());</stringProp>
        </JSR223Sampler>
        <hashTree/>
      </hashTree>

