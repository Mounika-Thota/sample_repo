<?xml version="1.0" encoding="UTF-8"?>
<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.6.3">
  <hashTree>
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="Atomic and Instant User Profile Update Validation" enabled="true">
      <stringProp name="TestPlan.comments">Performance test for user profile atomic update reliability</stringProp>
      <boolProp name="TestPlan.functional_mode">false</boolProp>
      <boolProp name="TestPlan.serialize_threadgroups">false</boolProp>
    </TestPlan>
    <hashTree>
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="Profile Update Thread Group" enabled="true">
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel">
          <boolProp name="LoopController.continue_forever">false</boolProp>
          <stringProp name="LoopController.loops">1</stringProp>
        </elementProp>
        <stringProp name="ThreadGroup.num_threads">10</stringProp>
        <stringProp name="ThreadGroup.ramp_time">30</stringProp>
        <longProp name="ThreadGroup.start_time">0</longProp>
        <longProp name="ThreadGroup.end_time">0</longProp>
        <boolProp name="ThreadGroup.scheduler">false</boolProp>
      </ThreadGroup>
      <hashTree>
        <CSVDataSet guiclass="TestBeanGUI" testclass="CSVDataSet" testname="User Profile CSV Data" enabled="true">
          <stringProp name="filename">user_profile_updates.csv</stringProp>
          <stringProp name="variableNames">user_id,update_type,profile_payload</stringProp>
          <stringProp name="delimiter">,</stringProp>
          <boolProp name="recycle">true</boolProp>
          <boolProp name="stopThread">false</boolProp>
          <boolProp name="shareMode">all</boolProp>
        </CSVDataSet>
        <hashTree/>
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="User Profile Update API" enabled="true">
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments"/>
          </elementProp>
          <stringProp name="HTTPSampler.domain">${__P(api_domain)}</stringProp>
          <stringProp name="HTTPSampler.port">${__P(api_port)}</stringProp>
          <stringProp name="HTTPSampler.protocol">${__P(api_protocol)}</stringProp>
          <stringProp name="HTTPSampler.path">${__P(profile_update_path)}</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
          <elementProp name="HTTPsampler.postBodyRaw" elementType="Arguments">
            <collectionProp name="Arguments.arguments">
              <elementProp name="" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.value">${profile_payload}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
        </HTTPSamplerProxy>
        <hashTree>
          <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="HTTP Header Manager" enabled="true">
            <collectionProp name="HeaderManager.headers">
              <elementProp name="" elementType="Header">
                <stringProp name="Header.name">Content-Type</stringProp>
                <stringProp name="Header.value">application/json</stringProp>
              </elementProp>
              <!-- Add authentication headers as needed
              <elementProp name="" elementType="Header">
                <stringProp name="Header.name">Authorization</stringProp>
                <stringProp name="Header.value">Bearer ${auth_token}</stringProp>
              </elementProp>
              -->
            </collectionProp>
          </HeaderManager>
          <hashTree/>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Profile Update Response Assertion" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp>200</stringProp>
            </collectionProp>
            <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">2</intProp>
          </ResponseAssertion>
          <hashTree/>
          <!-- Invalid update check: Use a separate assertion in CSV (e.g. type==invalid) to check for error code 400 or 422 -->
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Invalid Profile Update Assertion" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp>400</stringProp>
              <stringProp>422</stringProp>
            </collectionProp>
            <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">2</intProp>
            <!-- Only enable if ${update_type}==invalid; see instructions for conditional assertion implementation -->
          </ResponseAssertion>
          <hashTree/>
          <!-- Add response time assertion -->
          <DurationAssertion guiclass="DurationAssertionGui" testclass="DurationAssertion" testname="Profile Update Response Time Assertion" enabled="true">
            <longProp name="DurationAssertion.duration">1000</longProp>
          </DurationAssertion>
          <hashTree/>
        </hashTree>
        <ResultCollector guiclass="SummaryReportGui" testclass="ResultCollector" testname="Summary Report" enabled="true">
          <boolProp name="ResultCollector.error_logging">true</boolProp>
          <objProp>
            <name>saveConfig</name>
            <value class="SampleSaveConfiguration">
              <boolProp name="saveAsXml">false</boolProp>
              <boolProp name="responseData">false</boolProp>
              <boolProp name="samplerData">false</boolProp>
              <boolProp name="requestHeaders">false</boolProp>
              <boolProp name="responseHeaders">false</boolProp>
              <boolProp name="latency">true</boolProp>
              <boolProp name="time">true</boolProp>
              <boolProp name="success">true</boolProp>
              <boolProp name="label">true</boolProp>
              <boolProp name="code">true</boolProp>
              <boolProp name="threadName">true</boolProp>
              <boolProp name="dataType">false</boolProp>
              <boolProp name="assertions">true</boolProp>
              <boolProp name="subresults">false</boolProp>
            </value>
          </objProp>
          <stringProp name="filename">profile_update_summary.csv</stringProp>
        </ResultCollector>
        <hashTree/>
        <ResultCollector guiclass="ViewResultsTreeGui" testclass="ResultCollector" testname="View Results Tree" enabled="true">
          <boolProp name="ResultCollector.error_logging">true</boolProp>
          <objProp>
            <name>saveConfig</name>
            <value class="SampleSaveConfiguration">
              <boolProp name="saveAsXml">false</boolProp>
              <boolProp name="responseData">false</boolProp>
              <boolProp name="samplerData">false</boolProp>
              <boolProp name="requestHeaders">false</boolProp>
              <boolProp name="responseHeaders">false</boolProp>
              <boolProp name="latency">true</boolProp>
              <boolProp name="time">true</boolProp>
              <boolProp name="success">true</boolProp>
              <boolProp name="label">true</boolProp>
              <boolProp name="code">true</boolProp>
              <boolProp name="threadName">true</boolProp>
              <boolProp name="dataType">false</boolProp>
              <boolProp name="assertions">true</boolProp>
              <boolProp name="subresults">false</boolProp>
            </value>
          </objProp>
          <stringProp name="filename"></stringProp>
        </ResultCollector>
        <hashTree/>
      </hashTree>
    </hashTree>
  </hashTree>
</jmeterTestPlan>