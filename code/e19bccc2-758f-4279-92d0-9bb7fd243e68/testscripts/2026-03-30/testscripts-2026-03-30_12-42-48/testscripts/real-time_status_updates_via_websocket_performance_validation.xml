        <!-- WebSocket Sampler: Each thread opens a WebSocket connection -->
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Open WebSocket Connection and Listen for Messages" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="script">
// TODO: Replace 'ws://your.websocket.endpoint/path' with the actual WebSocket endpoint
import org.java_websocket.client.WebSocketClient
import org.java_websocket.handshake.ServerHandshake
import java.net.URI
import java.util.concurrent.CountDownLatch

def wsUrl = vars.get('ws_url') ?: 'ws://your.websocket.endpoint/path' // Parameterize as needed

def messageCount = 0
int expectedMessages = 1 // Number of messages to expect per connection per test iteration
long maxAllowedLatencyMs = 1000 // SLA: 1 second
CountDownLatch latch = new CountDownLatch(expectedMessages)

def startTime = System.currentTimeMillis()
def latencies = []
def errorFlag = false

class PerfWebSocketClient extends WebSocketClient {
    PerfWebSocketClient(URI serverUri) { super(serverUri) }
    void onOpen(ServerHandshake handshakedata) { }
    void onMessage(String message) {
        long receiveTime = System.currentTimeMillis()
        long latency = receiveTime - startTime
        latencies.add(latency)
        if (latency > maxAllowedLatencyMs) {
            errorFlag = true
            SampleResult.setResponseMessage('Message latency exceeded SLA: ' + latency + 'ms')
        }
        latch.countDown()
    }
    void onClose(int code, String reason, boolean remote) { }
    void onError(Exception ex) {
        errorFlag = true
        SampleResult.setResponseMessage('WebSocket error: ' + ex.getMessage())
    }
}

def client = new PerfWebSocketClient(new URI(wsUrl))
client.connectBlocking()
try {
    // Wait for messages or timeout
    if (!latch.await(maxAllowedLatencyMs + 500, java.util.concurrent.TimeUnit.MILLISECONDS)) {
        errorFlag = true
        SampleResult.setResponseMessage('Timeout waiting for message')
    }
} finally {
    client.close()
}
SampleResult.setSuccessful(!errorFlag)
SampleResult.setResponseData('Latencies: ' + latencies.toString(), 'UTF-8')
SampleResult.setResponseCode(errorFlag ? '500' : '200')
          </stringProp>
        </JSR223Sampler>
