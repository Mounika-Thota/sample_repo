              <idleTime>false</idleTime>
            </value>
          </objProp>
          <stringProp name="filename">${jtl_baseline}</stringProp>
        </ResultCollector>
        <hashTree/>
      </hashTree>
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="02 - Load (Sustain >= 50 RPS)" enabled="true">
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller" enabled="true">
          <boolProp name="LoopController.continue_forever">true</boolProp>
          <stringProp name="LoopController.loops">${load_loops}</stringProp>
        </elementProp>
        <stringProp name="ThreadGroup.num_threads">${load_threads}</stringProp>
        <stringProp name="ThreadGroup.ramp_time">${load_ramp_up}</stringProp>
        <boolProp name="ThreadGroup.scheduler">false</boolProp>
      </ThreadGroup>
      <hashTree>
        <ConstantThroughputTimer guiclass="TestBeanGUI" testclass="ConstantThroughputTimer" testname="Constant Throughput Timer (Target RPS)" enabled="true">
          <doubleProp>
            <name>throughput</name>
            <value>${__groovy((props.get('target_rps') ?: '50') as double * 60D)}</value>
          </doubleProp>
          <intProp name="calcMode">1</intProp>
        </ConstantThroughputTimer>
        <hashTree/>
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="Registry API - Initial Load (Resolved Endpoint)" enabled="true">
